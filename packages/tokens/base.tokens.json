{
  "$schema": "./schema.json",
  "version": 2,
  "name": "drx-dls base tokens",
  "comment": "STRUCTURE = source of truth for the shape of a theme, targeting WebAwesome's --wa-* token schema. Per-app drx.theme.json overrides only the `identity` inputs. Palette tints are mode-independent (WebAwesome's semantic layer handles light/dark).",

  "identity": {
    "variants": {
      "brand": "#f59e0b",
      "neutral": "#71717a",
      "success": "#16a34a",
      "warning": "#eab308",
      "danger": "#dc2626"
    },
    "radiusScale": 1.0,
    "spaceScale": 1.0,
    "fontSizeScale": 1.0,
    "borderWidthScale": 1.0,
    "fontFamily": {
      "body": "ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "heading": "ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
      "code": "ui-monospace, SFMono-Regular, 'SF Mono', Menlo, monospace"
    }
  },

  "tints": [95, 90, 80, 70, 60, 50, 40, 30, 20, 10, 5],

  "comment_devices": "Device layer drives WebAwesome's global scale knobs (--wa-*-scale). Identity is shared; only the scales differ per platform (tvOS = 10-foot, iOS = touch).",
  "devices": {
    "web": {
      "radiusScale": 1.0,
      "spaceScale": 1.0,
      "fontSizeScale": 1.0,
      "borderWidthScale": 1.0
    },
    "ios": {
      "radiusScale": 1.2,
      "spaceScale": 1.1,
      "fontSizeScale": 1.06,
      "borderWidthScale": 1.0
    },
    "tvos": {
      "radiusScale": 1.5,
      "spaceScale": 1.4,
      "fontSizeScale": 1.6,
      "borderWidthScale": 1.5
    }
  }
}

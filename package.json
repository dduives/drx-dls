{
  "name": "drx-dls",
  "version": "0.0.0",
  "private": true,
  "description": "DRX Design System — Radix-based, token-themeable, cross-platform (web + iOS/tvOS)",
  "license": "MIT",
  "author": "dduives <dries@duives.nl>",
  "repository": {
    "type": "git",
    "url": "https://github.com/dduives/drx-dls.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}

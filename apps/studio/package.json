{
  "name": "@drx-dls/studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Theme Studio — visual editor over @drx-dls/tokens; live-previews real WebAwesome components and exports drx.theme.json",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@awesome.me/webawesome": "^3.10.0",
    "@drx-dls/tokens": "*",
    "@drx-dls/webawesome": "*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "oxlint": "^1.71.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
